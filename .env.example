# Environment - copy to .env and fill in values

# ─── DATABASE ───────────────────────────────────────────
# SQLite (local dev - default, no setup needed)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production - use Neon/Railway/Supabase)
# DATABASE_URL="postgresql://user:password@host:5432/brew_db?schema=public"

# ─── AUTH ───────────────────────────────────────────────
JWT_SECRET="brew-super-secret-change-in-production-min-32-chars"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Admin credentials (used by seed script)
ADMIN_EMAIL="admin@cerveceria.com"
ADMIN_PASSWORD="brew-admin-2026"

# ─── API ────────────────────────────────────────────────
API_PORT=3001
API_PREFIX=api

# ─── FRONTEND ───────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# ─── CLOUDINARY (optional - for production image uploads) ───
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
